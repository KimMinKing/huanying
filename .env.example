# 라이플 DB 접속 정보
# 복사해서 사용: cp .env.example .env
# (Vite 프론트엔드는 현재 DB 직접 연결 안 함. 백엔드 도입 시 사용)

# PostgreSQL 컨테이너 설정 (docker-compose.yml과 일치)
POSTGRES_DB=lifful
POSTGRES_USER=lifful
POSTGRES_PASSWORD=lifful_pass
POSTGRES_PORT=5434

# 백엔드 도입 시 사용할 접속 문자열 (로컬에서 백엔드 실행할 때)
DATABASE_URL=postgresql://lifful:lifful_pass@localhost:5434/lifful

# 백엔드도 Docker로 실행할 때 (localhost 대신 서비스 이름)
# DATABASE_URL=postgresql://lifful:lifful_pass@postgres:5432/lifful

# 관리자 초기 계정 (db/schema.sql 시드용 — DATA.md에 평문 표기)
ADMIN_EMAIL=admin@lifful.com
ADMIN_PASSWORD=admin123
